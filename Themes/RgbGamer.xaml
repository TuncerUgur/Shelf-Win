<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background: Pure black -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="#EE050505"/>
    
    <!-- RGB Loop Border Brush -->
    <LinearGradientBrush x:Key="DockBorderBrush" x:Shared="False" StartPoint="0.5,0" EndPoint="0.5,1">
        <LinearGradientBrush.RelativeTransform>
            <RotateTransform CenterX="0.5" CenterY="0.5" Angle="0" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="#FF0000" Offset="0"/>     <!-- Red -->
        <GradientStop Color="#FFFF00" Offset="0.16"/>  <!-- Yellow -->
        <GradientStop Color="#00FF00" Offset="0.33"/>  <!-- Green -->
        <GradientStop Color="#00FFFF" Offset="0.5"/>   <!-- Cyan -->
        <GradientStop Color="#0000FF" Offset="0.66"/>  <!-- Blue -->
        <GradientStop Color="#FF00FF" Offset="0.83"/>  <!-- Magenta -->
        <GradientStop Color="#FF0000" Offset="1"/>     <!-- Back to Red -->
    </LinearGradientBrush>
    
    <CornerRadius x:Key="DockCornerRadius">12</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#00FFFF" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Storyboard x:Key="ThemeAnimation" RepeatBehavior="Forever">
        <!-- Spin the gradient angle -->
        <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                        From="0" To="720" Duration="0:0:6" />
        
        <!-- Pulse the shadow color exactly like RGB -->
        <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" Duration="0:0:6">
            <LinearColorKeyFrame Value="#FF0000" KeyTime="0:0:0"/>
            <LinearColorKeyFrame Value="#FFFF00" KeyTime="0:0:1"/>
            <LinearColorKeyFrame Value="#00FF00" KeyTime="0:0:2"/>
            <LinearColorKeyFrame Value="#00FFFF" KeyTime="0:0:3"/>
            <LinearColorKeyFrame Value="#0000FF" KeyTime="0:0:4"/>
            <LinearColorKeyFrame Value="#FF00FF" KeyTime="0:0:5"/>
            <LinearColorKeyFrame Value="#FF0000" KeyTime="0:0:6"/>
        </ColorAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#33FFFFFF"/>
    <CornerRadius x:Key="ItemCornerRadius">6</CornerRadius>
    <Thickness x:Key="ItemMargin">5</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="White"/>
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#FFFFFFFF"/>
</ResourceDictionary>
