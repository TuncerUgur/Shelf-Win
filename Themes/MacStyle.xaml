<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background: Whiteish glassy -->
    <LinearGradientBrush x:Key="DockBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#C0F5F5F7" Offset="0"/>
        <GradientStop Color="#90E5E5EA" Offset="1"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="DockBorderBrush" Color="#66FFFFFF"/>
    <CornerRadius x:Key="DockCornerRadius">24</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="25" ShadowDepth="10" Color="#55000000" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#33000000"/>
    <CornerRadius x:Key="ItemCornerRadius">6</CornerRadius>
    <Thickness x:Key="ItemMargin">4</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="#222222"/> <!-- Dark label -->
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#22000000"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#66000000"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#FF000000"/>
</ResourceDictionary>
