<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Background: Deep dark forest green -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="#EE0A1812"/>
    <SolidColorBrush x:Key="DockBorderBrush" Color="#88B89947"/> <!-- Gold/Brass edge -->
    <CornerRadius x:Key="DockCornerRadius">10</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Color="#000000" Opacity="0.9"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#33B89947"/> <!-- Soft gold highlight -->
    <CornerRadius x:Key="ItemCornerRadius">6</CornerRadius>
    <Thickness x:Key="ItemMargin">4</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="#FFDDBB77"/> <!-- Pale soft gold -->
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#33B89947"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#88B89947"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#FFDDBB77"/>
</ResourceDictionary>
