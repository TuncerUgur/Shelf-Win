<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background: Pure matte white/gray with black wireframe borders -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="#EEF7F7F7"/>
    <SolidColorBrush x:Key="DockBorderBrush" Color="#222222"/>
    <CornerRadius x:Key="DockCornerRadius">4</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#222222" Opacity="0.1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#11000000"/>
    <CornerRadius x:Key="ItemCornerRadius">4</CornerRadius>
    <Thickness x:Key="ItemMargin">5</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="#222222"/>
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#22000000"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#66000000"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#222222"/>
</ResourceDictionary>
