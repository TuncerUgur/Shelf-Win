<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="#A1000000"/>
    <SolidColorBrush x:Key="DockBorderBrush" Color="#33FFFFFF"/>
    <CornerRadius x:Key="DockCornerRadius">12</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#44FFFFFF"/>
    <CornerRadius x:Key="ItemCornerRadius">8</CornerRadius>
    <Thickness x:Key="ItemMargin">3</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="White"/>
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#FFFFFFFF"/>
</ResourceDictionary>
