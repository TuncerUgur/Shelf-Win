<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background: Neon Sunset Gradient -->
    <LinearGradientBrush x:Key="DockBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#CC1E0033" Offset="0"/> <!-- Dark Purple -->
        <GradientStop Color="#CC7A0066" Offset="0.5"/> <!-- Magenta -->
        <GradientStop Color="#CCFF5500" Offset="1"/> <!-- Neon Orange -->
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="DockBorderBrush" Color="#EEFF5500"/>
    <CornerRadius x:Key="DockCornerRadius">2</CornerRadius>
    
    <Style x:Key="DockBorderStyle" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#FF5500" Opacity="1.0"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Storyboard x:Key="ThemeAnimation" RepeatBehavior="Forever" AutoReverse="True">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                        From="15" To="40" Duration="0:0:3" />
        <ColorAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)"
                        From="#FF5500" To="#FF00CC" Duration="0:0:4" />
    </Storyboard>

    <!-- Item Styles -->
    <SolidColorBrush x:Key="ItemNormalBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#66FF00CC"/>
    <CornerRadius x:Key="ItemCornerRadius">2</CornerRadius>
    <Thickness x:Key="ItemMargin">4</Thickness>

    <!-- Label Specs -->
    <SolidColorBrush x:Key="LabelForegroundBrush" Color="#FFE700"/> <!-- Synthwave Yellow -->
    
    <!-- Window Button Spec -->
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#44FFE700"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#AAFFE700"/>
    <SolidColorBrush x:Key="ButtonHoverForegroundBrush" Color="#FFFFFF"/>
</ResourceDictionary>
