<Window x:Class="DockShelf.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Shelf-Win" Height="350" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F3F3F3" WindowStyle="ToolWindow">
    <StackPanel Margin="20">
        <Image Source="Assets/Icon.png" Width="64" Height="64" Margin="0,0,0,10"/>
        <TextBlock Text="Shelf-Win v1.0.0" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Developed by Uğur Tuncer" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5"/>
        
        <Separator Margin="0,15"/>
        
        <TextBlock Text="Explore my other projects:" FontWeight="SemiBold" Margin="0,0,0,10"/>
        
        <Button Content="📅 Kaçıncı Haftadayız? (Web)" Click="OpenWebsite_Click" 
                Padding="10,5" Margin="0,5" Cursor="Hand" Background="White"/>
        
        <Button Content="☕ Support me (Buy Me a Coffee)" Click="OpenDonate_Click" 
                Padding="10,5" Margin="0,5" Cursor="Hand" Background="#FFDD00" FontWeight="Bold"/>

        <TextBlock Text="Thank you for using Shelf-Win!" 
                   FontSize="10" Foreground="Silver" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </StackPanel>
</Window>